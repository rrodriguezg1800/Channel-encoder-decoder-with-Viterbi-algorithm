// ==========================================================
// Decod_Viterbi_K3  (ACS por destino, SOLO FLUSH + padding 00)
// - Escribe en TB: DATA_BITS + PAD_STEPS
// - En flush: salta PAD_STEPS (padding) y guarda DATA_BITS reales
// ==========================================================
module Decod_Viterbi_K3 #(
    parameter integer L     = 20, // más historia de traceback
    parameter integer DEPTH = 50
)(
    input  wire       clk,
    input  wire       rst,
    input  wire       par_valido_i,
    input  wire [1:0] dec_in_i,

    output reg        bit_decod_o,
    output reg [9:0]  salida_final_o,
    output reg        listo_o
);

    // ---------------- configuración de trama ----------------
    localparam integer DATA_BITS    = 10;                 // bits reales
    localparam integer TAIL_BITS    = 2;                  // K-1 (K=3)
    localparam integer PAD_STEPS    = L + TAIL_BITS;      // 20 + 2 = 22
    localparam integer TOTAL_STEPS  = DATA_BITS + PAD_STEPS; // 10 + 22 = 32
    localparam [5:0]   INF          = 6'd63;

`ifndef SYNTHESIS
    initial if (DEPTH < TOTAL_STEPS)
        $error("DEPTH=%0d < TOTAL_STEPS=%0d (aumenta DEPTH)", DEPTH, TOTAL_STEPS);
`endif

    // Estados A=00, B=01, C=10, D=11
    localparam A=2'b00, B=2'b01, C=2'b10, D=2'b11;

    // Controles de frame
    reg [$clog2(TOTAL_STEPS):0] step_cnt_q;
    reg [$clog2(DATA_BITS):0]   out_cnt_q;
    reg                         flush_q, flush_arm_q;

    // contador de saltos al iniciar flush (para no copiar el padding)
    reg [$clog2(PAD_STEPS+1)-1:0] skip_cnt_q;

    // Métricas y actividad
    reg [5:0] M_A, M_B, M_C, M_D;
    reg       act_A, act_B, act_C, act_D;

    // ---------- Distancias de Hamming ----------
    wire [1:0] d00, d01, d10, d11;

    // Padding robusto (cuenta pares REALES y luego genera PAD_STEPS pasos 00)
    wire       wr_en_step;
    wire [1:0] dec_in_eff;
    wire       pad_active;
    wire [$clog2(PAD_STEPS+1)-1:0] pad_cnt;  // sólo debug

    HammingGen_K3 hamming_inst (
        .dec_in_i(dec_in_eff),
        .d00(d00), .d01(d01), .d10(d10), .d11(d11)
    );

    // *** NUEVO: PaddingGen_K3 SIN step_cnt_i ***
    PaddingGen_K3 #(.DATA_BITS(DATA_BITS), .PAD_STEPS(PAD_STEPS)) pad_inst (
        .clk(clk),
        .rst(rst),
        .par_valido_i(par_valido_i),
        .dec_in_i(dec_in_i),
        .wr_en_step_o(wr_en_step),      // paso válido (real o padding)
        .dec_in_eff_o(dec_in_eff),      // 00 durante padding
        .pad_active_o(pad_active),
        .pad_cnt_o(pad_cnt)
    );

    // ---------- Candidatos por DESTINO ----------
    wire [5:0] cand_A_from_A = act_A ? (M_A + {4'b0, d00}) : INF;
    wire [5:0] cand_A_from_B = act_B ? (M_B + {4'b0, d11}) : INF;

    wire [5:0] cand_B_from_C = act_C ? (M_C + {4'b0, d10}) : INF;
    wire [5:0] cand_B_from_D = act_D ? (M_D + {4'b0, d01}) : INF;

    // *** FIX: B->C usa d00 ***
    wire [5:0] cand_C_from_A = act_A ? (M_A + {4'b0, d11}) : INF;
    wire [5:0] cand_C_from_B = act_B ? (M_B + {4'b0, d00}) : INF;

    wire [5:0] cand_D_from_C = act_C ? (M_C + {4'b0, d01}) : INF;
    wire [5:0] cand_D_from_D = act_D ? (M_D + {4'b0, d10}) : INF;

    // Resultados ACS combinacionales
    reg [5:0] best_A_c, best_B_c, best_C_c, best_D_c;
    reg [1:0] best_A_pred, best_B_pred, best_C_pred, best_D_pred;
    reg       best_A_u,   best_B_u,   best_C_u,   best_D_u;
    reg       next_act_A, next_act_B, next_act_C, next_act_D;

    // estado final = mínimo global
    reg [5:0] gmin_c; reg [1:0] end_state_c;
    wire [1:0] end_state_w;
    wire [5:0] gmin_w;

    MetricSelector_K3 selector_inst (
        .mA(best_A_c), .mB(best_B_c), .mC(best_C_c), .mD(best_D_c),
        .enA(next_act_A), .enB(next_act_B), .enC(next_act_C), .enD(next_act_D),
        .min_state_o(end_state_w),
        .min_metric_o(gmin_w)
    );

    // Empaque de survivors (pred y u)
    wire [7:0] surv_pred_pack = {best_D_pred, best_C_pred, best_B_pred, best_A_pred};
    wire [3:0] surv_u_pack    = {best_D_u,    best_C_u,    best_B_u,    best_A_u  };

    // Traceback (solo FLUSH)
    wire tb_valido_w, tb_bit_w;
    Traceback_K3 #(.DEPTH(DEPTH), .L(L)) tb_inst (
        .clk(clk), .rst(rst),
        .wr_en_i(wr_en_step),
        .flush_i(flush_q),
        .surv_pred_i(surv_pred_pack),
        .surv_u_i   (surv_u_pack),
        .end_state_i(end_state_c),
        .valido_o(tb_valido_w),
        .bit_o(tb_bit_w)
    );

    // ----------------- ACS combinacional -----------------
    always @* begin
        // A <= min( A--u0/00 , B--u0/11 )
        next_act_A  = act_A | act_B;
        if (cand_A_from_A <= cand_A_from_B) begin
            best_A_c    = cand_A_from_A; best_A_pred = A; best_A_u = 1'b0;
        end else begin
            best_A_c    = cand_A_from_B; best_A_pred = B; best_A_u = 1'b0;
        end

        // B <= min( C--u0/10 , D--u0/01 )
        next_act_B  = act_C | act_D;
        if (cand_B_from_C <= cand_B_from_D) begin
            best_B_c    = cand_B_from_C; best_B_pred = C; best_B_u = 1'b0;
        end else begin
            best_B_c    = cand_B_from_D; best_B_pred = D; best_B_u = 1'b0;
        end

        // C <= min( A--u1/11 , B--u1/00 )
        next_act_C  = act_A | act_B;
        if (cand_C_from_A <= cand_C_from_B) begin
            best_C_c    = cand_C_from_A; best_C_pred = A; best_C_u = 1'b1;
        end else begin
            best_C_c    = cand_C_from_B; best_C_pred = B; best_C_u = 1'b1;
        end

        // D <= min( C--u1/01 , D--u1/10 )
        next_act_D  = act_C | act_D;
        if (cand_D_from_C <= cand_D_from_D) begin
            best_D_c    = cand_D_from_C; best_D_pred = C; best_D_u = 1'b1;
        end else begin
            best_D_c    = cand_D_from_D; best_D_pred = D; best_D_u = 1'b1;
        end

        // Mínimo global
        end_state_c = end_state_w;
        gmin_c      = gmin_w;

`ifndef SYNTHESIS
        $display("ACS: gmin=%0d, estado_final=%b", gmin_c, end_state_c);
`endif
    end

    // ---------------- Secuencial ----------------
    always @(posedge clk or posedge rst) begin
        if (rst) begin
            M_A<=0; M_B<=INF; M_C<=INF; M_D<=INF;
            act_A<=1; act_B<=0; act_C<=0; act_D<=0;

            step_cnt_q<=0; out_cnt_q<=0;
            flush_q<=1'b0; flush_arm_q<=1'b0;

            skip_cnt_q<=0;

            bit_decod_o<=1'b0; salida_final_o<=10'd0; listo_o<=1'b0;

        end else begin
            // Avanzar ACS si hay paso (real o padding)
            if (wr_en_step) begin
                M_A   <= next_act_A ? best_A_c : INF;
                M_B   <= next_act_B ? best_B_c : INF;
                M_C   <= next_act_C ? best_C_c : INF;
                M_D   <= next_act_D ? best_D_c : INF;

                act_A <= next_act_A;
                act_B <= next_act_B;
                act_C <= next_act_C;
                act_D <= next_act_D;

                if (step_cnt_q < TOTAL_STEPS) step_cnt_q <= step_cnt_q + 1'b1;
                if (step_cnt_q == TOTAL_STEPS-1) flush_arm_q <= 1'b1; // listo para flush
            end

            // Disparo de flush (precargar saltos de padding)
            if (flush_arm_q) begin
                flush_q     <= 1'b1;
                flush_arm_q <= 1'b0;
                skip_cnt_q  <= PAD_STEPS[$clog2(PAD_STEPS+1)-1:0]; // saltar padding
                out_cnt_q   <= 0;  // por si reusaras el bloque
            end

            // Consumir TB: primero saltar padding, luego DATA_BITS reales (MSB→LSB)
            if (flush_q && tb_valido_w) begin
                if (skip_cnt_q != 0) begin
                    skip_cnt_q <= skip_cnt_q - 1'b1;
                end else if (out_cnt_q < DATA_BITS) begin
                    bit_decod_o    <= tb_bit_w;
                    salida_final_o <= {tb_bit_w, salida_final_o[9:1]};
                    out_cnt_q      <= out_cnt_q + 1'b1;

                    if (out_cnt_q == DATA_BITS-1) begin
                        listo_o <= 1'b1;
                        flush_q <= 1'b0; // fin del frame
                    end else begin
                        listo_o <= 1'b0;
                    end
                end
            end else begin
                listo_o <= 1'b0;
            end
        end
    end

endmodule
